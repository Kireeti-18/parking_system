{
  "name": "my-turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "start_db": "sudo docker rm -f parking_system && sudo docker run --name parking_system -e POSTGRES_PASSWORD=Kireeti@123 -d -p 5432:5432 -v parking_system_data:/var/lib/postgresql/data postgres",
    "prisma_studio": "cd packages/db && npx prisma studio"
  },
  "devDependencies": {
    "@types/google.maps": "^3.58.1",
    "@types/node": "^24.9.2",
    "prettier": "^3.6.2",
    "turbo": "^2.5.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.7.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.0.1",
    "@react-google-maps/api": "^2.20.7",
    "axios": "^1.12.2",
    "clsx": "^2.1.1",
    "jotai": "^2.15.0",
    "next-auth": "^4.24.11",
    "react-outside-click-handler": "^1.3.0",
    "react-use": "^17.6.0",
    "uuid": "^13.0.0"
  }
}
