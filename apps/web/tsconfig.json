{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "noImplicitAny": false,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts",
    "components/Logo.tsx",
    "components/MapComponent.tsx",
    "components/MapProvider.tsx",
    "components/ClientRoute.tsx"
  ],
  "exclude": ["node_modules"]
}
