// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("NEXT_PUBLIC_DATABASE_URL")
}

model User {
  id                    String    @id @default(uuid())
  name                  String 
  email                 String    @unique
  password              String 
  avathar               String    @default("boy-1")  
  verification_status   Boolean   @default(false)
  user_type             String
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  parkingAreaStaff     ParkingAreaStaff[] 
  parkings_parked_by    Parkings[] @relation("ParkedByUser")
  parkings_departed_by  Parkings[] @relation("DepartedByUser")
  setting               Setting?
}

model Setting {
  id               String   @id @default(uuid())
  user_id          String   @unique
  nearest_count    Int      @default(5)
  nearest_distance Int      @default(100)
  notifications    Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("settings")
}

model Token {
  id                    String    @id @default(uuid())
  email                 String 
  token                 String    
  token_type            String
  other_info            Json      @default("{}")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model ParkingArea {
  id                   String   @id @default(uuid())
  name                 String
  parking_location     Json     @default("{}")
  bike_slots           Int
  car_slots            Int
  is_opened            Boolean
  pricing_type         String
  car_price_per_hour   Decimal  @db.Decimal(10,2) @default(0.1)
  bike_price_per_hour  Decimal  @db.Decimal(10,2) @default(0.1)
  car_fine_price       Decimal  @db.Decimal(10,2) @default(0)
  bike_fine_price      Decimal  @db.Decimal(10,2) @default(0)
  verification_status  Boolean
  meta_data            Json     @default("{}")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  admins               ParkingAreaStaff[]
  parkings             Parkings[]

  @@map("parking_area") 
}

model ParkingAreaStaff {
  user_id              String 
  user_type            String
  parking_area_id      String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User         @relation(fields: [user_id], references: [id])
  parkingArea          ParkingArea  @relation(fields: [parking_area_id], references: [id])

  entryParkings        Parkings[] @relation("EntryAdminOnArea")
  departureParkings    Parkings[] @relation("DepartureAdminOnArea")

  @@id([user_id, parking_area_id])
  @@map("parking_area_admin") 
}

model Parkings {
  id                               String   @id @default(cuid())
  private_id                       String
  parked_user_id                   String
  depature_user_id                 String?
  parking_entry_admin_id           String?
  parking_depature_admin_id        String?
  parking_area_id                  String
  vehicle_number                   String
  vehicle_type                     String
  slot_number                      Int
  status                           String
  fine                             String?
  fine_desc                        String?
  fined_slot                       String?
  fined_time                       String?
  entry_time_stamp                 DateTime   @default(now())
  depature_time_stamp              DateTime?
  other_info                       Json     @default("{}")
  createdAt                        DateTime   @default(now())
  updatedAt                        DateTime   @updatedAt

  parkedBy        User               @relation("ParkedByUser", fields: [parked_user_id], references: [id])
  departedBy      User?              @relation("DepartedByUser", fields: [depature_user_id], references: [id])
  parkingArea     ParkingArea        @relation(fields: [parking_area_id], references: [id])
  entryAdmin      ParkingAreaStaff?  @relation("EntryAdminOnArea", fields: [parking_entry_admin_id, parking_area_id], references: [user_id, parking_area_id])
  departureAdmin  ParkingAreaStaff?  @relation("DepartureAdminOnArea", fields: [parking_depature_admin_id, parking_area_id], references: [user_id, parking_area_id])

  @@map("parkings")
}
